# PostgreSQL connection string
DATABASE_URL=postgresql://incident_user:incident_pass@postgres:5432/incident_platform

# Redis connection
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional initial admin user
DEFAULT_ADMIN_EMAIL=admin@platform.com
DEFAULT_ADMIN_PASSWORD=Admin@123

# Supabase connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq AI config (get your key at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Datadog / metrics
DATADOG_API_KEY=
DATADOG_HOST=127.0.0.1
DATADOG_PORT=8125
DATADOG_METRIC_PREFIX=incident_platform
SERVICE_NAME=incident-management-backend

# Alert targets
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
SMTP_URL=smtp://user:pass@smtp.example.com:587
ALERT_EMAIL_FROM=alerts@incident-platform.local
ALERT_EMAIL_TO=ops@example.com
